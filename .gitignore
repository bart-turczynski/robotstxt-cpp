# Build output (default `build/` plus any maintainer build dirs, e.g.
# build-diff/ for the differential harness, build-ci/, build-default/).
build/
build*/
*.o
*.a
*.so
*.dylib
*.dll

# Pinned upstream source cache — a frozen input, reproducible via the fetch in
